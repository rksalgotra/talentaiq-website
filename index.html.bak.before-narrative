.pillar-num{font-family:var(--fm);font-size:10px;color:var(--t4);letter-spacing:.1em;margin-bottom:.75rem}
.pillar-icon{font-size:2rem;margin-bottom:.75rem}
.pillar-h{font-family:var(--fd);font-size:1.3rem;font-weight:700;margin-bottom:.5rem}
.pillar-h.find{color:var(--brand)}
.pillar-h.hire{color:var(--green)}
.pillar-h.grow{color:var(--amber)}
.pillar-p{font-size:.88rem;line-height:1.7;color:var(--t2)}
.pillar-line{position:absolute;bottom:0;left:0;right:0;height:3px}
.pillar-line.find{background:linear-gradient(90deg,var(--brand),var(--brand-l))}
.pillar-line.hire{background:linear-gradient(90deg,var(--green),#10b981)}
.pillar-line.grow{background:linear-gradient(90deg,var(--amber),#f59e0b)}

/* ── TRUST ── */
.trust-strip{position:relative;z-index:10;border-top:1px solid var(--border);border-bottom:1px solid var(--border);background:var(--bg2);padding:1.5rem 0}.ts-inner{max-width:1200px;margin:0 auto;padding:0 2rem;display:flex;align-items:center;gap:2rem;flex-wrap:wrap}.ts-label{font-family:var(--fm);font-size:11px;letter-spacing:.07em;color:var(--t3);flex-shrink:0}.ts-items{display:flex;gap:2rem;flex-wrap:wrap}.ts-item{font-size:13px;color:var(--t2);font-weight:500}
section{position:relative;z-index:10;padding:6rem 0}.sw{max-width:1200px;margin:0 auto;padding:0 2rem}
.eyebrow{font-family:var(--fm);font-size:11px;letter-spacing:.1em;color:var(--brand);margin-bottom:.75rem}.s-h2{font-family:var(--fd);font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:700;line-height:1.12;letter-spacing:-.02em;margin-bottom:1rem;color:var(--t1)}.s-lead{font-size:1rem;line-height:1.8;color:var(--t2);max-width:540px}

/* ── FIND SECTION ── */
.find-sec{background:var(--bg)}
.fhg-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;margin-top:3rem}
.fhg-content{max-width:480px}
.fhg-features{list-style:none;margin-top:1.5rem}
.fhg-features li{display:flex;align-items:flex-start;gap:10px;margin-bottom:1rem;font-size:.9rem;color:var(--t2);line-height:1.6}
.fhg-features li .check{width:22px;height:22px;border-radius:50%;display:grid;place-items:center;font-size:10px;flex-shrink:0;margin-top:2px}
.check.brand{background:var(--brand-dim);border:1px solid var(--brand-b);color:var(--brand)}
.check.green{background:var(--green-dim);border:1px solid rgba(5,150,105,.2);color:var(--green)}
.check.amber{background:var(--amber-dim);border:1px solid rgba(217,119,6,.2);color:var(--amber)}

/* ── HERO UI CARD ── */
.hui-card{background:white;border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:0 16px 48px rgba(0,0,0,.08)}
.hui-topbar{background:var(--bg2);padding:10px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border)}.hui-title{font-family:var(--fm);font-size:10px;letter-spacing:.08em;color:var(--t3)}.hui-live{display:flex;align-items:center;gap:5px;font-family:var(--fm);font-size:10px;color:var(--green)}.hui-live-dot{width:5px;height:5px;border-radius:50%;background:var(--green);animation:pulseGreen 2s ease infinite}
.hui-body{padding:16px}.hui-role-h{font-size:12px;font-weight:600;color:var(--t1);margin-bottom:2px}.hui-role-s{font-size:10px;color:var(--t3);margin-bottom:14px}
.hui-cand{display:flex;align-items:center;gap:10px;padding:10px;border-radius:10px;margin-bottom:6px}.hui-cand.top{background:var(--brand-dim);border:1px solid var(--brand-b)}.hui-cand.c2{background:rgba(37,99,235,.05);border:1px solid rgba(37,99,235,.12)}.hui-cand.c3{background:rgba(124,58,237,.05);border:1px solid rgba(124,58,237,.12)}
.hui-av{width:34px;height:34px;border-radius:50%;display:grid;place-items:center;font-size:11px;font-weight:700;flex-shrink:0}.hui-info{flex:1;min-width:0}.hui-name{font-size:12px;font-weight:600;color:var(--t1)}.hui-role-sm{font-size:10px;color:var(--t3);margin-bottom:4px}.hui-bar-track{height:3px;background:var(--bg3);border-radius:2px;overflow:hidden}.hui-bar-fill{height:100%;border-radius:2px}.hui-score{text-align:right;flex-shrink:0}.hui-pct{font-family:var(--fd);font-size:16px;font-weight:700;display:block}.hui-tier{font-family:var(--fm);font-size:8px;letter-spacing:.06em;display:block}.tier-best{color:var(--brand)}.tier-good{color:var(--blue)}.tier-fair{color:var(--purple)}
.hui-explain{background:var(--bg2);border:1px solid var(--border);border-radius:8px;padding:10px;margin-top:10px}.hui-explain-label{font-family:var(--fm);font-size:9px;color:var(--brand);letter-spacing:.06em;margin-bottom:5px}.hui-explain-text{font-size:10px;color:var(--t2);line-height:1.5}

/* ── HIRE SECTION ── */
.hire-sec{background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
.pipeline-visual{background:white;border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,.06)}
.pipe-header{background:var(--bg2);padding:10px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.pipe-title{font-family:var(--fm);font-size:10px;letter-spacing:.08em;color:var(--t3)}
.pipe-body{padding:16px;display:flex;gap:8px}
.pipe-col{flex:1;text-align:center}
.pipe-stage{font-family:var(--fm);font-size:8px;letter-spacing:.06em;color:var(--t3);margin-bottom:6px}
.pipe-count{font-family:var(--fd);font-size:20px;font-weight:700;color:var(--t1)}
.pipe-bar{height:4px;border-radius:2px;margin-top:6px}
.pipe-sla{display:flex;justify-content:space-between;padding:10px 16px;border-top:1px solid var(--border);background:var(--bg2)}
.pipe-sla-item{font-size:10px;color:var(--t3)}.pipe-sla-item strong{color:var(--t1)}

/* ── GROW SECTION ── */
.grow-sec{background:var(--bg)}
.grow-visual{background:white;border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,.06)}
.grow-header{background:var(--bg2);padding:10px 16px;border-bottom:1px solid var(--border)}
.grow-body{padding:16px}
.grow-match{display:flex;align-items:center;gap:10px;padding:10px;border-radius:10px;margin-bottom:8px;background:var(--amber-dim);border:1px solid rgba(217,119,6,.15)}
.grow-match-av{width:32px;height:32px;border-radius:50%;background:rgba(217,119,6,.12);color:var(--amber);display:grid;place-items:center;font-size:11px;font-weight:700}
.grow-match-info{flex:1}.grow-match-name{font-size:12px;font-weight:600;color:var(--t1)}.grow-match-meta{font-size:10px;color:var(--t3)}
.grow-match-score{font-family:var(--fd);font-size:15px;font-weight:700;color:var(--amber)}

/* ── HOW IT WORKS ── */
.hiw-sec{background:var(--bg2);border-top:1px solid var(--border)}.hiw-head{max-width:580px;margin-bottom:4rem}
.hiw-steps{display:grid;grid-template-columns:repeat(5,1fr);gap:1rem;position:relative}.hiw-steps::before{content:'';position:absolute;top:28px;left:8%;right:8%;height:2px;background:linear-gradient(90deg,transparent,var(--brand-b) 20%,var(--brand-b) 80%,transparent)}.hiw-step{text-align:center}.hiw-num{width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,var(--brand),var(--purple));display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-weight:700;font-size:1.1rem;color:white;margin:0 auto 1.2rem;box-shadow:0 4px 16px rgba(79,70,229,.3)}.hiw-h{font-size:.875rem;font-weight:600;color:var(--t1);margin-bottom:.5rem}.hiw-p{font-size:.8rem;line-height:1.6;color:var(--t2)}

/* ── ENTERPRISE VALUE ── */
.ev-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem;margin-top:3rem}.ev-card{background:white;border:1px solid var(--border);border-radius:16px;padding:2rem;transition:border-color .3s,transform .4s}.ev-card:hover{border-color:var(--brand-b);transform:translateY(-4px);box-shadow:0 8px 24px rgba(0,0,0,.06)}.ev-metric{font-family:var(--fd);font-size:2rem;font-weight:700;color:var(--brand);margin-bottom:.25rem}.ev-metric-l{font-family:var(--fm);font-size:9px;letter-spacing:.08em;color:var(--t3);margin-bottom:1rem}.ev-h{font-size:.9rem;font-weight:600;color:var(--t1);margin-bottom:.5rem}.ev-p{font-size:.85rem;line-height:1.7;color:var(--t2)}

/* ── CAPABILITIES ── */
.caps-sec{background:var(--bg);border-top:1px solid var(--border)}.caps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-top:3rem}.cap-card{background:white;border:1px solid var(--border);border-radius:14px;padding:1.6rem;transition:border-color .3s,transform .4s}.cap-card:hover{border-color:var(--brand-b);transform:translateY(-4px);box-shadow:0 8px 24px rgba(0,0,0,.06)}.cap-icon{font-size:1.4rem;margin-bottom:1rem}.cap-h{font-size:.925rem;font-weight:600;color:var(--t1);margin-bottom:.5rem}.cap-p{font-size:.84rem;line-height:1.65;color:var(--t2)}

/* ── CTA ── */
.cta-sec{background:linear-gradient(135deg,var(--brand),var(--purple));text-align:center;position:relative;overflow:hidden;padding:6rem 0}.cta-inner{max-width:680px;margin:0 auto;position:relative;z-index:2}.cta-h{font-family:var(--fd);font-size:clamp(1.8rem,3.5vw,2.8rem);font-weight:700;letter-spacing:-.02em;line-height:1.12;margin-bottom:1.2rem;color:white}.cta-sub{font-size:1.05rem;color:rgba(255,255,255,.8);line-height:1.7;margin-bottom:2.5rem}.cta-sec .btn-primary{background:white;color:var(--brand);box-shadow:0 4px 16px rgba(0,0,0,.15)}.cta-sec .btn-primary:hover{background:#f8fafc;transform:translateY(-2px)}.cta-sec .btn-secondary{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);color:white}.cta-sec .btn-secondary:hover{background:rgba(255,255,255,.25)}.cta-stats{display:flex;justify-content:center;gap:3rem;margin-top:2.5rem}.cs-item{text-align:center}.cs-num{font-family:var(--fd);font-size:1.8rem;font-weight:700;color:white;display:block}.cs-label{font-size:.78rem;color:rgba(255,255,255,.65)}

/* ── FOOTER ── */
footer{border-top:1px solid var(--border);padding:3.5rem 0 2.5rem;background:var(--bg)}.footer-grid{max-width:1200px;margin:0 auto;padding:0 2rem;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem}.footer-brand .nav-wordmark{font-size:20px;margin-bottom:.75rem;display:block}.footer-brand p{font-size:.85rem;color:var(--t3);line-height:1.7;max-width:260px}.footer-col h4{font-size:.8rem;font-weight:600;color:var(--t2);letter-spacing:.06em;text-transform:uppercase;margin-bottom:1rem}.footer-col a{display:block;font-size:.85rem;color:var(--t3);text-decoration:none;margin-bottom:.6rem;transition:color .2s}.footer-col a:hover{color:var(--t1)}.footer-bottom{max-width:1200px;margin:2.5rem auto 0;padding:1.5rem 2rem 0;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}.footer-copy{font-size:.8rem;color:var(--t3)}.footer-links{display:flex;gap:1.5rem}.footer-links a{font-size:.8rem;color:var(--t3);text-decoration:none;transition:color .2s}.footer-links a:hover{color:var(--t1)}
@keyframes fadeUp{from{transform:translateY(28px);opacity:0}to{transform:translateY(0);opacity:1}}
@keyframes levitate{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
@keyframes pulseBrand{0%,100%{box-shadow:0 0 4px var(--brand)}50%{box-shadow:0 0 12px var(--brand),0 0 24px rgba(79,70,229,.3)}}
@keyframes pulseGreen{0%,100%{box-shadow:0 0 3px var(--green)}50%{box-shadow:0 0 8px var(--green)}}
.reveal{opacity:0;transform:translateY(24px);transition:opacity .7s ease,transform .7s ease}.reveal.visible{opacity:1;transform:translateY(0)}
@media(max-width:1024px){.pillars{grid-template-columns:1fr}.fhg-grid{grid-template-columns:1fr;gap:2rem}.hiw-steps{grid-template-columns:1fr;gap:1.5rem}.hiw-steps::before{display:none}.ev-grid,.caps-grid{grid-template-columns:1fr 1fr}.footer-grid{grid-template-columns:1fr 1fr}}
@media(max-width:600px){nav .nav-links{display:none}.sw{padding:0 1.25rem}.ev-grid,.caps-grid{grid-template-columns:1fr}.cta-stats{flex-direction:column;gap:1rem}.footer-grid{grid-template-columns:1fr}}
</style>
