.nav-wordmark{font-family:var(--fd);font-size:18px;font-weight:700;color:var(--t1)}.nav-wordmark b{color:var(--brand)}
.nav-links{display:flex;gap:.1rem}.nav-a{color:var(--t2);text-decoration:none;font-size:14px;font-weight:500;padding:8px 14px;border-radius:8px;transition:all .2s}.nav-a:hover{color:var(--t1);background:var(--bg2)}
.nav-end{display:flex;align-items:center;gap:.75rem}.nav-ghost{color:var(--t2);font-size:14px;font-weight:500;text-decoration:none;padding:8px 14px;border-radius:8px;transition:all .2s}.nav-ghost:hover{color:var(--t1)}
.nav-cta{background:var(--brand);color:white;font-size:14px;font-weight:600;padding:9px 22px;border-radius:8px;text-decoration:none;transition:all .2s;box-shadow:0 2px 8px rgba(79,70,229,.25)}.nav-cta:hover{background:var(--brand-d);transform:translateY(-1px);box-shadow:0 6px 20px rgba(79,70,229,.35)}
.hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;padding:120px 0 80px;background:linear-gradient(170deg,#eef2ff 0%,#fff 35%,#f8fafc 70%,#eef2ff 100%)}
.hero-bg{position:absolute;inset:0;pointer-events:none}.hb-gradient{position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 20% 30%,rgba(79,70,229,.08) 0%,transparent 60%),radial-gradient(ellipse 40% 40% at 80% 70%,rgba(124,58,237,.06) 0%,transparent 50%)}
.hb-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(79,70,229,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(79,70,229,.04) 1px,transparent 1px);background-size:64px 64px;mask-image:radial-gradient(ellipse 80% 70% at 50% 50%,black 0%,transparent 75%)}
.hero-inner{max-width:1200px;margin:0 auto;padding:0 2rem;position:relative;z-index:2}
.hero-center{text-align:center;max-width:780px;margin:0 auto}
.hero-kicker{display:inline-flex;align-items:center;gap:8px;padding:5px 14px 5px 8px;background:var(--brand-dim);border:1px solid var(--brand-b);border-radius:999px;margin-bottom:2rem;animation:fadeUp .8s ease .2s both}
.hk-dot{width:6px;height:6px;border-radius:50%;background:var(--brand);box-shadow:0 0 8px rgba(79,70,229,.4);animation:pulseBrand 2.4s ease-in-out infinite}.hk-text{font-family:var(--fm);font-size:11px;font-weight:500;color:var(--brand);letter-spacing:.05em}
